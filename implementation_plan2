## WS1: Database & Sync Layer

### 1.1 Polymorphic Document Schema

All documents share a flat PouchDB database using the **Type Discriminator** pattern with ULID-prefixed `_id` values.

#### Document ID Convention
```
{type}:{outlet_id}:{ulid}

Examples:
  item:OUT001:01J5KXYZ...       → Menu item
  order:OUT001:01J5KXYZ...      → Order
  table:OUT001:01J5KXYZ...      → Table
  party:OUT001:01J5KXYZ...      → Party (queue→seated flow)
  inv:OUT001:01J5KXYZ...        → Inventory SKU record
  cat:OUT001:01J5KXYZ...        → Category
  taxgrp:OUT001:01J5KXYZ...     → Tax group
  addongrp:OUT001:01J5KXYZ...   → Add-on group
  staff:OUT001:01J5KXYZ...      → Staff/user
  outlet:OUT001                  → Outlet config
  device:OUT001:DEV01            → Device registration
```

> [!NOTE]
> ULID provides chronological sort order on `allDocs` and prefixed `_id` enables efficient range queries: `db.allDocs({ startkey: 'order:OUT001:', endkey: 'order:OUT001:\ufff0' })`.

#### Polymorphic Item Schema

```typescript
// ════════════════════════════════════════════
//  BASE ITEM — shared fields across all kinds
// ════════════════════════════════════════════
interface BaseItem {
  _id: string;                    // "item:OUT001:01J5..."
  _rev?: string;
  type: "item";
  schema_version: 1;

  // ─── Identity ───
  name: string;                   // "Chicken Biryani"
  display_name?: string;          // Override for digital menu
  sku?: string;                   // Barcode/SKU
  category_id: string;            // Ref → cat doc
  tags: string[];                 // ["bestseller", "spicy", "veg"]

  // ─── Pricing (all amounts in paise) ───
  base_price: number;             // ₹250 = 25000
  tax_config: {
    tax_group_id: string;         // Ref → taxgrp doc
    is_inclusive: boolean;        // MRP-style inclusive pricing?
  };

  // ─── Availability ───
  is_available: boolean;
  available_channels: ("dine_in" | "takeaway" | "delivery" | "digital_menu")[];
  outlet_id: string;

  // ─── Polymorphic Discriminator ───
  item_kind: "simple" | "recipe" | "combo" | "variant_parent";

  // ─── Add-on Groups (shared across all kinds) ───
  addon_group_ids: string[];      // Ref → addongrp docs

  // ─── Metadata ───
  sort_order: number;
  image_url?: string;
  created_at: string;             // ISO 8601
  updated_at: string;
  is_deleted: boolean;            // Soft delete for sync
}

// ═══════════ SIMPLE ITEM (retail/beverages) ═══════════
interface SimpleItem extends BaseItem {
  item_kind: "simple";
  inventory: {
    track: boolean;
    unit: "pcs" | "kg" | "litre" | "ml" | "g";
    current_stock: number;
    low_stock_alert: number;
  };
}

// ═══════════ RECIPE ITEM (kitchen-prepared) ═══════════
// NOTE: Recipe is stored for V2 auto-deduction.
//       V1 only uses the recipe for reference display.
//       Stock is tracked at SKU level, not ingredient level.
interface RecipeItem extends BaseItem {
  item_kind: "recipe";
  recipe: {
    yield_qty: number;
    yield_unit: string;
    ingredients: RecipeIngredient[];
    prep_time_minutes?: number;
    instructions?: string;
  };
  inventory: {
    track: boolean;               // V1: track finished dish count
    unit: "pcs";
    current_stock: number;
    low_stock_alert: number;
  };
}

interface RecipeIngredient {
  inventory_item_id: string;      // Ref → inv doc (raw material)
  name: string;                   // Denormalized for offline display
  quantity: number;               // Per single serving
  unit: "g" | "kg" | "ml" | "litre" | "pcs";
  waste_percentage?: number;
}

// ═══════════ COMBO ITEM ═══════════
interface ComboItem extends BaseItem {
  item_kind: "combo";
  combo: {
    components: {
      item_id: string;
      item_name: string;          // Denormalized
      quantity: number;
      is_optional: boolean;
    }[];
    combo_discount: number;       // In paise
  };
}

// ═══════════ VARIANT PARENT (Pizza → S/M/L) ═══════════
interface VariantParentItem extends BaseItem {
  item_kind: "variant_parent";
  variants: ItemVariant[];
}

interface ItemVariant {
  variant_id: string;
  name: string;                   // "Large", "Regular"
  price_override: number;         // Absolute price in paise
  sku?: string;
  inventory: {
    track: boolean;
    unit: "pcs" | "kg" | "litre" | "ml" | "g";
    current_stock: number;
    low_stock_alert: number;
  };
}

// ═══════════ DISCRIMINATED UNION ═══════════
type PolymorphicItem = SimpleItem | RecipeItem | ComboItem | VariantParentItem;
```

